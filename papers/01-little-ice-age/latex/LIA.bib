  title        = {Numerare Est Errare: Agricultural Output and Food Supply in England Before and During the Industrial Revolution},
  volume       = {73}
}

@article{pfister_economic_2022,
  abstract     = {New data are used to construct a time series of real {GDP} in Germany for the period 1500–1850 using an indirect output estimation technique that relies on wages, prices, and sectoral employment. Until the mid-seventeenth century, real {GDP} per capita moved inversely with population. The eighteenth century saw a modest rise in output per head. From the late 1810s, economic growth gradually accelerated. The results shed new light on the reversal of fortunes in early modern Europe and the transition from a Malthusian regime to modern economic growth.},
