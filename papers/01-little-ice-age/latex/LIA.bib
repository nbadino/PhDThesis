@article{martinez-gonzalez_assessing_2020,
  abstract     = {British pre-industrial economic growth has traditionally been analysed from the Malthusian point of view and other more optimistic approaches, but in many cases, ignoring environmental factors. This article explores the inclusion of the climate in this general debate, focusing on one of the colder periods of the last 500 years, known as the Maunder Minimum. The provisional results suggest that climate change and the resulting adaptations may have influenced the start of the English Agricultural Revolution, the Energy Transition and the European Divergence. However, from an econometric point of view these results are not fully conclusive, making it necessary to continue working with better primary sources and other alternative methodologies.},
  author       = {Martínez-González, José Luis and Suriñach, Jordi and Jover, Gabriel and Martín-Vide, Javier and Barriendos-Vallvé, Mariano and Tello, Enric},
  date         = {2020-05-01},
  issn         = {1573-1480},
  journaltitle = {Climatic Change},
  keywords     = {Energy, Economic growth, Agriculture, Climate impacts, Early modern age, England, Work},
  langid       = {english},
  number       = {2},
  pages        = {233--249},
  shortjournal = {Climatic Change},
  shorttitle   = {Assessing climate impacts on English economic growth (1645–1740)},
  title        = {Assessing climate impacts on English economic growth (1645–1740): an econometric approach},
  volume       = {160}
}

@article{tello_onset_2017-1,
  abstract     = {The English Agricultural Revolution began during a period of climate change in which temperatures decreased significantly. Lower temperatures meant less bacterial activity, a slower release of mineral nitrogen into cultivated soils, and a shorter growing season for crops—a combination that tended to diminish yields. The English farmers reacted by increasing the flow of organic matter and manure into the soil, thus mitigating the negative effect of the colder temperatures to some extent. When the temperatures rose again, the faster mineralization of soil organic matter led to bountiful yields that encouraged English farmers to continue with these innovative strategies. The upshot is that the English agricultural revolution was more a discovery than an invention, that the English agricultural revolution was more a discovery than an invention, induced by a combination of climate challenges, social and institutional settings, and market incentives.},
  author       = {Tello, Enric and Martínez, José Luis and Jover-Avellà, Gabriel and Olarieta, José Ramón and García-Ruiz, Roberto and de Molina, Manuel González and Badia-Miró, Marc and Winiwarter, Verena and Koepke, Nikola},
  date         = {2017-02-01},
  issn         = {0022-1953},
  journaltitle = {The Journal of Interdisciplinary History},
  number       = {4},
  pages        = {445--474},
  shortjournal = {The Journal of Interdisciplinary History},
  shorttitle   = {The Onset of the English Agricultural Revolution},
  title        = {The Onset of the English Agricultural Revolution: Climate Factors and Soil Nutrients},
  volume       = {47}
}

