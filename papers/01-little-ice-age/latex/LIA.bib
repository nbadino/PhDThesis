  rights       = {https://www.elsevier.com/tdm/userlicense/1.0/},
  shortjournal = {Earth and Planetary Science Letters},
  title        = {Reconstruction of temperature in the Central Alps during the past 2000 yr from a δ18O stalagmite record},
  volume       = {235}
}

@article{dreu_climatic_2018,
  abstract     = {Human history is shaped by landmark discoveries in science and technology. However, across both time and space the rate of innovation is erratic: Periods of relative inertia alternate with bursts of creative science and rapid cascades of technological innovations. While the origins of the rise and fall in rates of discovery and innovation remain poorly understood, they may reflect adaptive responses to exogenously emerging threats and pressures. Here we examined this possibility by fitting annual rates of scientific discovery and technological innovation to climatic variability and its associated economic pressures and resource scarcity. In time-series data from Europe (1500–1900CE), we indeed found that rates of innovation are higher during prolonged periods of cold (versus warm) surface temperature and during the presence (versus absence) of volcanic dust veils. This negative temperature–innovation link was confirmed in annual time-series for France, Germany, and the United Kingdom (1901–1965CE). Combined, across almost 500 years and over 5,000 documented innovations and discoveries, a 0.5°C increase in temperature associates with a sizable 0.30–0.60 standard deviation decrease in innovation. Results were robust to controlling for fluctuations in population size. Furthermore, and consistent with economic theory and micro-level data on group innovation, path analyses revealed that the relation between harsher climatic conditions between 1500–1900CE and more innovation is mediated by climate-induced economic pressures and resource scarcity.},
  author       = {Dreu, Carsten K. W. De and Dijk, Mathijs A. van},
  date         = {2018-01-24},
  issn         = {1932-6203},
  journaltitle = {{PLOS} {ONE}},
  keywords     = {Dust, Europe, France, Germany, Paleoclimatology, Surface temperature, Volcanoes, Wheat},
  langid       = {english},
  note         = {Publisher: Public Library of Science},
  number       = {1},
  pages        = {e0190122},
  shortjournal = {{PLOS} {ONE}},
  title        = {Climatic shocks associate with innovation in science and technology},
  volume       = {13}
}

@article{waldinger_economic_2022,
  abstract     = {Recent studies consistently find important economic effects of year-to-year weather fluctuations. I study the economic effects of long-term and gradual climate change over 250 years in the Little Ice Age (1600–1850), during which people and economies had time to adapt. Results show significant negative economic effects of long-term climate change. Temperature impacted the economy through its effect on agricultural productivity and mortality. To adapt to the Little Ice Age, economies increased trade and changed land use. I discuss the relevance of these results for understanding the impact of today’s climate change, especially in developing countries.},
  author       = {Waldinger, Maria},
  date         = {2022-09},
  issn         = {0022-3808},
  journaltitle = {Journal of Political Economy},
  note         = {Publisher: The University of Chicago Press},
  number       = {9},
  pages        = {2275--2314},
  shorttitle   = {The Economic Effects of Long-Term Climate Change},
  title        = {The Economic Effects of Long-Term Climate Change: Evidence from the Little Ice Age},
  volume       = {130}
}

