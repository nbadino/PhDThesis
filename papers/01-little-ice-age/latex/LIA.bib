@article{mangini_reconstruction_2005,
  abstract     = {The precisely dated isotopic composition of a stalagmite from Spannagel Cave in the Central Alps is translated into a highly resolved record of temperature at high elevation during the past 2000 yr. Temperature maxima during the Medieval Warm Period between 800 and 1300 {AD} are in average about 1.7 8C higher than the minima in the Little Ice Age and similar to present-day values. The high correlation of this record to D14C suggests that solar variability was a major driver of climate in Central Europe during the past 2 millennia.},
  author       = {Mangini, A. and Spötl, C. and Verdes, P.},
  date         = {2005-07},
  issn         = {0012821X},
